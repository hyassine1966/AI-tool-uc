                    <input type="text" class="form-input" id="addCompanyName" placeholder="Bv. Acme Consulting">
                </div>
                <div class="form-field">
                    <label class="form-label">Land</label>
                    <select class="form-select" id="addCompanyCountry">
                        <option value="BE">België (BE)</option>
                        <option value="NL">Nederland (NL)</option>
                    </select>
                </div>
                <div class="form-field">
                    <label class="form-label">Status</label>
                    <select class="form-select" id="addCompanyStatus">
                        <option value="bevestigd">Bevestigd</option>
                        <option value="waarschijnlijk">Waarschijnlijk</option>
                        <option value="mogelijk" selected>Mogelijk</option>
                    </select>
                </div>
            </div>
            <div class="form-field">
                <label class="form-label">Detail / notitie</label>
                <textarea class="form-textarea" id="addCompanyDetail" placeholder="Korte omschrijving van het gebruik"></textarea>
            </div>
        </div>

        <!-- TOOL panel -->
        <div class="add-panel" data-panel="tool">
            <div class="form-field">
                <label class="form-label">Domein</label>
                <select class="form-select" id="addToolDomain"></select>
            </div>
            <div class="form-field">
                <label class="form-label">Toolnaam</label>
                <input type="text" class="form-input" id="addToolName" placeholder="Bv. AnthropicClaude Enterprise">
            </div>
            <div class="form-field">
                <label class="form-label">Beschrijving</label>
                <textarea class="form-textarea" id="addToolDesc" placeholder="Korte beschrijving van de tool"></textarea>
            </div>
        </div>

        <!-- DOMAIN panel -->
        <div class="add-panel" data-panel="domain">
            <div class="form-field">
                <label class="form-label">Domeinnaam</label>
                <input type="text" class="form-input" id="addDomainName" placeholder="Bv. Legal AI">
            </div>
            <div class="form-field">
                <label class="form-label">Subtitel (optioneel)</label>
                <input type="text" class="form-input" id="addDomainMeta" placeholder="Bv. nieuw domein">
            </div>
        </div>

        <div class="modal-actions">
            <button class="modal-btn" onclick="closeAddModal()">Annuleren</button>
            <button class="modal-btn primary" onclick="submitAdd()">Toevoegen</button>
        </div>
    </div>
</div>

<!-- TOAST -->
<div class="toast" id="toast"></div>

<!-- EDIT BANNER -->
<div class="edit-banner" onclick="toggleEditMode()">
    <span class="edit-dot"></span>
    <span id="editLabel">Bewerkingsmodus Aan</span>
</div>

<script>
    // === STATUS OPTIES (pas labels hier aan) ===
    const statuses = [
        { value: 'bevestigd', label: 'Bevestigd' },
        { value: 'waarschijnlijk', label: 'Waarschijnlijk' },
        { value: 'mogelijk', label: 'Mogelijk' }
    ];

    function ddHTML(cur) {
        return statuses.map(s => `
            <button class="status-dd-opt ${s.value === cur ? 'sel' : ''}" data-val="${s.value}" onclick="pickStatus(this,event)">
                <span class="dd-dot"></span>${s.label}<span class="dd-check">&#10003;</span>
            </button>`).join('');
    }

    // Init dropdowns
    document.querySelectorAll('.status-badge').forEach(b => {
        b.querySelector('.status-dd').innerHTML = ddHTML(b.dataset.status);
    });

    function toggleStatusDD(btn) {
        const dd = btn.querySelector('.status-dd');
        const open = dd.classList.contains('open');
        document.querySelectorAll('.status-dd').forEach(d => d.classList.remove('open'));
        document.querySelectorAll('.company-row.dd-open').forEach(r => r.classList.remove('dd-open'));
        if (!open) {
            dd.innerHTML = ddHTML(btn.dataset.status);
            dd.classList.add('open');
            const row = btn.closest('.company-row');
            if (row) row.classList.add('dd-open');
        }
    }

    function pickStatus(opt, e) {
        e.stopPropagation();
        const btn = opt.closest('.status-badge');
        const v = opt.dataset.val;
        const lbl = statuses.find(s => s.value === v).label;
        btn.dataset.status = v;
        btn.childNodes.forEach(n => { if (n.nodeType === 3) n.textContent = lbl; });
        btn.querySelector('.status-dd').classList.remove('open');
        const row = btn.closest('.company-row');
        if (row) row.classList.remove('dd-open');
    }

    document.addEventListener('click', e => {
        if (!e.target.closest('.status-badge')) {
            document.querySelectorAll('.status-dd').forEach(d => d.classList.remove('open'));
            document.querySelectorAll('.company-row.dd-open').forEach(r => r.classList.remove('dd-open'));
        }
    });

    // === DOMAIN COLLAPSE ===
    function toggleDomain(header) {
        header.closest('.domain-group').classList.toggle('collapsed');
    }

    // === FILTER STATE ===
    let currentStatusFilter = 'all';
    let currentCountryFilter = 'all';
    let currentSearchQuery = '';

    // === FILTER BY STATUS ===
    function filterByStatus(status, btn) {
        document.querySelectorAll('.filter-dot-btn:not(.country-filter-btn)').forEach(b => b.classList.remove('active'));
        btn.classList.add('active');
        currentStatusFilter = status;
        applyAllFilters();
    }

    // === FILTER BY COUNTRY ===
    function filterByCountry(country, btn) {
        document.querySelectorAll('.country-filter-btn').forEach(b => b.classList.remove('active'));
        btn.classList.add('active');
        currentCountryFilter = country;
        applyAllFilters();
    }

    // === SEARCH ===
    function searchAll(q) {
        currentSearchQuery = (q || '').toLowerCase();
        applyAllFilters();
    }

    // === APPLY ALL FILTERS (status + country + search) ===
    function applyAllFilters() {
        const q = currentSearchQuery;
        document.querySelectorAll('.company-row').forEach(row => {
            const badge = row.querySelector('.status-badge');
            const statusVal = badge ? badge.dataset.status : '';
            const countryVal = row.dataset.country || 'BE';
            const statusOk = (currentStatusFilter === 'all' || statusVal === currentStatusFilter);
            const countryOk = (currentCountryFilter === 'all' || countryVal === currentCountryFilter);
            let searchOk = true;
            if (q) {
                const name = (row.querySelector('.company-row-name') || {}).textContent || '';
                const detail = (row.querySelector('.company-row-detail') || {}).textContent || '';
                const card = row.closest('.company-card');
                const toolName = card ? (card.querySelector('.tool-card-name') || {}).textContent || '' : '';
                const toolDesc = card ? (card.querySelector('.tool-card-desc') || {}).textContent || '' : '';
                const hay = (name + ' ' + detail + ' ' + toolName + ' ' + toolDesc).toLowerCase();
                searchOk = hay.includes(q);
            }
            row.style.display = (statusOk && countryOk && searchOk) ? '' : 'none';
        });
        document.querySelectorAll('.company-card').forEach(card => {
            const visible = card.querySelectorAll('.company-row:not([style*="display: none"])');
            card.style.display = visible.length > 0 ? '' : 'none';
        });
        document.querySelectorAll('.domain-group').forEach(g => {
            const vis = g.querySelectorAll('.company-card:not([style*="display: none"])');
            g.style.display = vis.length > 0 ? '' : 'none';
        });
    }

    // === COUNTRY CHIP RENDERING ===
    function countryChipHTML(country) {
        const c = (country === 'NL') ? 'NL' : 'BE';
        const flagCls = (c === 'NL') ? 'flag-nl' : 'flag-be';
        const label = (c === 'NL') ? 'NL' : 'BE';
        return `<span class="country-chip" data-country-chip="${c}"><span class="country-flag-sm ${flagCls}"></span>${label}</span>`;
    }
    function ensureCountryChip(row) {
        if (!row) return;
        let chip = row.querySelector(':scope > .country-chip');
        const c = row.dataset.country || 'BE';
        if (!chip) {
            row.insertAdjacentHTML('afterbegin', countryChipHTML(c));
        } else {
            chip.outerHTML = countryChipHTML(c);
        }
    }
    function renderAllCountryChips() {
        document.querySelectorAll('.company-row').forEach(r => ensureCountryChip(r));
    }

    // === EDIT MODE ===
    let editMode = true;
    function toggleEditMode() {
        editMode = !editMode;
        document.querySelectorAll('[contenteditable]').forEach(el => el.contentEditable = editMode);
        document.getElementById('editLabel').textContent = editMode ? 'Bewerkingsmodus Aan' : 'Bewerkingsmodus Uit';
        document.querySelector('.edit-dot').style.background = editMode ? '#4ade80' : '#94a3b8';
    }

    // === TOAST ===
    function showToast(msg) {
        const t = document.getElementById('toast');
        t.textContent = msg;
        t.classList.add('show');
        clearTimeout(t._tm);
        t._tm = setTimeout(() => t.classList.remove('show'), 3000);
    }

    // === EXPORT TO EXCEL ===
    function exportToExcel(e) {
        if (e) e.preventDefault();
        const rows = [['Domein','Tool','Tool Beschrijving','Land','Bedrijf','Detail','Status']];
        document.querySelectorAll('.domain-group').forEach(group => {
            const domainTitle = (group.querySelector('.domain-title') || {}).textContent || '';
            group.querySelectorAll('.company-card').forEach(card => {
                const toolName = (card.querySelector('.tool-card-name') || {}).textContent || '';
                const toolDesc = (card.querySelector('.tool-card-desc') || {}).textContent || '';
                card.querySelectorAll('.company-row').forEach(row => {
                    const name = (row.querySelector('.company-row-name') || {}).textContent || '';
                    const detail = (row.querySelector('.company-row-detail') || {}).textContent || '';
                    const badge = row.querySelector('.status-badge');
                    const statusVal = badge ? badge.dataset.status : '';
                    const statusLbl = (statuses.find(s => s.value === statusVal) || {}).label || statusVal;
                    const country = row.dataset.country || 'BE';
                    const countryLbl = (country === 'NL') ? 'Nederland' : 'België';
                    rows.push([domainTitle, toolName, toolDesc, countryLbl, name, detail, statusLbl]);
                });
            });
        });

        const wb = XLSX.utils.book_new();
        const ws = XLSX.utils.aoa_to_sheet(rows);
        // Column widths
        ws['!cols'] = [
            { wch: 32 }, { wch: 28 }, { wch: 40 },
            { wch: 12 }, { wch: 36 }, { wch: 48 }, { wch: 14 }
        ];
        XLSX.utils.book_append_sheet(wb, ws, 'Competitor AI Tools');
        const today = new Date().toISOString().slice(0, 10);
        XLSX.writeFile(wb, `competitor-ai-tools_${today}.xlsx`);
        showToast(`Geëxporteerd: ${rows.length - 1} rijen naar Excel`);
    }

    // === IMPORT FROM TXT ===
    function openImportModal(e) {
        if (e) e.preventDefault();
        document.getElementById('importModal').classList.add('open');
    }
    function closeImportModal() {
        document.getElementById('importModal').classList.remove('open');
        document.getElementById('importFileInput').value = '';
    }

    function handleImportFile(e) {
        const file = e.target.files[0];
        if (!file) return;
        const reader = new FileReader();
        reader.onload = evt => {
            const text = evt.target.result;
            try {
                const stats = parseAndImportTxt(text);
                closeImportModal();
                showToast(`Import klaar: +${stats.domains} domeinen, +${stats.tools} tools, +${stats.rows} bedrijfsrijen`);
                updateStats();
                if (typeof injectDeleteButtons === 'function') injectDeleteButtons();
            } catch (err) {
                alert('Importfout: ' + err.message);
            }
        };
        reader.readAsText(file);
    }

    function parseAndImportTxt(text) {
        const lines = text.split(/\r?\n/);
        let currentDomain = null, currentTool = null;
        let newDomains = 0, newTools = 0, newRows = 0;
        const mainEl = document.querySelector('.main');

        for (let raw of lines) {
            const line = raw.trim();
            if (!line) continue;

            // Domain line
            if (line.startsWith('# ') && !line.startsWith('## ')) {
                const name = line.slice(2).trim();
                currentDomain = findOrCreateDomain(name, mainEl);
                if (currentDomain.created) newDomains++;
                currentTool = null;
                continue;
            }
            // Tool line
            if (line.startsWith('## ')) {
                if (!currentDomain) throw new Error('Tool zonder domein (regel: ' + line + ')');
                const parts = line.slice(3).split('|').map(s => s.trim());
                const toolName = parts[0];
                const toolDesc = parts[1] || '';
                currentTool = findOrCreateTool(currentDomain.group, toolName, toolDesc);
                if (currentTool.created) newTools++;
                continue;
            }
            // Company row line
            if (line.startsWith('- ') || line.startsWith('* ')) {
                if (!currentTool) throw new Error('Bedrijfsrij zonder tool (regel: ' + line + ')');
                const parts = line.slice(2).split('|').map(s => s.trim());
                const companyName = parts[0];
                const detail = parts[1] || '';
                const statusRaw = (parts[2] || 'mogelijk').toLowerCase();
                const status = ['bevestigd','waarschijnlijk','mogelijk'].includes(statusRaw) ? statusRaw : 'mogelijk';
                const countryRaw = (parts[3] || 'BE').toUpperCase().trim();
                const country = (countryRaw === 'NL') ? 'NL' : 'BE';
                addCompanyRow(currentTool.card, companyName, detail, status, country);
                newRows++;
            }
        }
        return { domains: newDomains, tools: newTools, rows: newRows };
    }

    function findOrCreateDomain(name, mainEl) {
        let found = null;
        document.querySelectorAll('.domain-group').forEach(g => {
            const t = (g.querySelector('.domain-title') || {}).textContent || '';
            if (t.trim().toLowerCase() === name.toLowerCase()) found = g;
        });
        if (found) return { group: found, created: false };

        // Create new domain
        const g = document.createElement('div');
        g.className = 'domain-group';
        g.innerHTML = `
            <div class="domain-header" onclick="toggleDomain(this)">
                <div class="domain-accent"></div>
                <div class="domain-title" contenteditable="true">${escapeHtml(name)}</div>
                <div class="domain-meta" contenteditable="true">geïmporteerd</div>
                <div class="domain-toggle"><svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2.5" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="m4.5 15.75 7.5-7.5 7.5 7.5"/></svg></div>
            </div>
            <div class="companies-grid"></div>
        `;
        mainEl.appendChild(g);
        return { group: g, created: true };
    }

    function findOrCreateTool(domainGroup, toolName, toolDesc) {
        let found = null;
        domainGroup.querySelectorAll('.company-card').forEach(c => {
            const n = (c.querySelector('.tool-card-name') || {}).textContent || '';
            if (n.trim().toLowerCase() === toolName.toLowerCase()) found = c;
        });
        if (found) return { card: found, created: false };

        const card = document.createElement('div');
        card.className = 'company-card';
        card.innerHTML = `
            <div class="tool-card-header">
                <div class="tool-card-name" contenteditable="true">${escapeHtml(toolName)}</div>
                <div class="tool-card-count">0 Bedrijven</div>
            </div>
            <div class="tool-card-desc" contenteditable="true">${escapeHtml(toolDesc)}</div>
        `;
        domainGroup.querySelector('.companies-grid').appendChild(card);
        return { card: card, created: true };
    }

    function addCompanyRow(card, name, detail, status, country) {
        const row = document.createElement('div');
        row.className = 'company-row';
        const c = (country === 'NL') ? 'NL' : 'BE';
        row.dataset.country = c;
        const statusLbl = (statuses.find(s => s.value === status) || {}).label || 'Mogelijk';
        row.innerHTML = `
            ${countryChipHTML(c)}
            <div class="company-row-info">
                <div class="company-row-name" contenteditable="true">${escapeHtml(name)}</div>
                <div class="company-row-detail" contenteditable="true">${escapeHtml(detail)}</div>
            </div>
            <button class="status-badge" data-status="${status}" onclick="toggleStatusDD(this)">${statusLbl}<div class="status-dd"></div></button>
        `;
        card.appendChild(row);
        // Init dropdown for the new badge
        const badge = row.querySelector('.status-badge');
        badge.querySelector('.status-dd').innerHTML = ddHTML(status);
        // Update count chip
        const countEl = card.querySelector('.tool-card-count');
        if (countEl) {
            const n = card.querySelectorAll('.company-row').length;
            countEl.textContent = n + (n === 1 ? ' Bedrijf' : ' Bedrijven');
        }
        // Respect current filters for the newly added row
        if (typeof applyAllFilters === 'function') applyAllFilters();
    }

    function escapeHtml(s) {
        return String(s).replace(/[&<>"']/g, c => ({'&':'&amp;','<':'&lt;','>':'&gt;','"':'&quot;',"'":'&#39;'})[c]);
    }

    // ============================================
    //   SERIALIZATION (used by Excel/TXT export)
    // ============================================
    function serializeState() {
        const domains = [];
        document.querySelectorAll('.domain-group').forEach(g => {
            const title = (g.querySelector('.domain-title') || {}).textContent || '';
            const meta = (g.querySelector('.domain-meta') || {}).textContent || '';
            const isBig5 = g.classList.contains('big5');
            const tools = [];
            g.querySelectorAll('.company-card').forEach(card => {
                const toolName = (card.querySelector('.tool-card-name') || {}).textContent || '';
                const toolDesc = (card.querySelector('.tool-card-desc') || {}).textContent || '';
                const rows = [];
                card.querySelectorAll('.company-row').forEach(row => {
                    rows.push({
                        name: (row.querySelector('.company-row-name') || {}).textContent || '',
                        detail: (row.querySelector('.company-row-detail') || {}).textContent || '',
                        status: (row.querySelector('.status-badge') || {}).dataset ? row.querySelector('.status-badge').dataset.status : 'mogelijk',
                        country: row.dataset.country || 'BE'
                    });
                });
                tools.push({ name: toolName, desc: toolDesc, rows: rows });
            });
            domains.push({ title: title, meta: meta, big5: isBig5, tools: tools });
        });
        return {
            version: 1,
            updatedAt: new Date().toISOString(),
            updatedBy: '',
            hero: {
                title: document.querySelector('.hero-title').innerHTML,
                subtitle: document.querySelector('.hero-subtitle').textContent
            },
            domains: domains
        };
    }

    function deserializeState(state) {
        if (!state || !state.domains) throw new Error('Ongeldige data');
        if (state.hero) {
            if (state.hero.title) document.querySelector('.hero-title').innerHTML = state.hero.title;
            if (state.hero.subtitle) document.querySelector('.hero-subtitle').textContent = state.hero.subtitle;
        }
        const mainEl = document.querySelector('.main');
        mainEl.innerHTML = '';
        state.domains.forEach(d => {
            const g = document.createElement('div');
            g.className = 'domain-group' + (d.big5 ? ' big5' : '');
            g.innerHTML = `
                <div class="domain-header" onclick="toggleDomain(this)">
                    <div class="domain-accent"></div>
                    <div class="domain-title" contenteditable="true">${escapeHtml(d.title)}</div>
                    <div class="domain-meta" contenteditable="true">${escapeHtml(d.meta)}</div>
                    <div class="domain-toggle"><svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2.5" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="m4.5 15.75 7.5-7.5 7.5 7.5"/></svg></div>
                </div>
                <div class="companies-grid"></div>
            `;
            const grid = g.querySelector('.companies-grid');
            d.tools.forEach(t => {
                const card = document.createElement('div');
                card.className = 'company-card';
                const count = t.rows.length;
                card.innerHTML = `
                    <div class="tool-card-header">
                        <div class="tool-card-name" contenteditable="true">${escapeHtml(t.name)}</div>
                        <div class="tool-card-count">${count} ${count === 1 ? 'Bedrijf' : 'Bedrijven'}</div>
                    </div>
                    <div class="tool-card-desc" contenteditable="true">${escapeHtml(t.desc)}</div>
                `;
                t.rows.forEach(r => {
                    const status = ['bevestigd','waarschijnlijk','mogelijk'].includes(r.status) ? r.status : 'mogelijk';
                    const lbl = (statuses.find(s => s.value === status) || {}).label || 'Mogelijk';
                    const country = (r.country === 'NL') ? 'NL' : 'BE';
                    const rowEl = document.createElement('div');
                    rowEl.className = 'company-row';
                    rowEl.dataset.country = country;
                    rowEl.innerHTML = `
                        ${countryChipHTML(country)}
                        <div class="company-row-info">
                            <div class="company-row-name" contenteditable="true">${escapeHtml(r.name)}</div>
                            <div class="company-row-detail" contenteditable="true">${escapeHtml(r.detail)}</div>
                        </div>
                        <button class="status-badge" data-status="${status}" onclick="toggleStatusDD(this)">${lbl}<div class="status-dd"></div></button>
                    `;
                    rowEl.querySelector('.status-badge .status-dd').innerHTML = ddHTML(status);
                    card.appendChild(rowEl);
                });
                grid.appendChild(card);
            });
            mainEl.appendChild(g);
        });
    }

    // === UPDATE STATS BAR ===
    function updateStats() {
        const domains = document.querySelectorAll('.domain-group').length;
        const tools = document.querySelectorAll('.company-card').length;
        const companySet = new Set();
        document.querySelectorAll('.company-row').forEach(row => {
            const nameEl = row.querySelector('.company-row-name');
            const name = nameEl ? nameEl.textContent.trim().toLowerCase() : '';
            const country = (row.dataset.country || 'BE');
            if (name) companySet.add(country + '::' + name);
        });
        document.getElementById('statDomains').textContent = domains;
        document.getElementById('statTools').textContent = tools;
        document.getElementById('statCompanies').textContent = companySet.size;
    }

    // === INIT ON LOAD ===
    document.addEventListener('DOMContentLoaded', function() {
        renderAllCountryChips();
        injectDeleteButtons();
        updateStats();
    });

    // ============================================
    //   MANAGE / DELETE MODE
    // ============================================
    function toggleManageMode(e) {
        if (e) e.preventDefault();
        document.body.classList.toggle('manage-mode');
        const link = document.getElementById('manageToggleLink');
        if (link) {
            const on = document.body.classList.contains('manage-mode');
            link.classList.toggle('active', on);
            link.textContent = on ? 'Beheer aan' : 'Beheer';
        }
        // Make sure buttons exist on any items added since load
        injectDeleteButtons();
    }

    function injectDeleteButtons() {
        // Rows
        document.querySelectorAll('.company-row').forEach(row => {
            if (!row.querySelector('.delete-btn-row')) {
                const b = document.createElement('button');
                b.type = 'button';
                b.className = 'delete-btn delete-btn-row';
                b.title = 'Bedrijf verwijderen';
                b.innerHTML = '&times;';
                b.setAttribute('onclick', 'deleteRow(this, event)');
                row.appendChild(b);
            }
        });
        // Tool cards
        document.querySelectorAll('.company-card').forEach(card => {
            const header = card.querySelector('.tool-card-header');
            if (header && !header.querySelector('.delete-btn-tool')) {
                const b = document.createElement('button');
                b.type = 'button';
                b.className = 'delete-btn delete-btn-tool';
                b.title = 'Tool verwijderen';
                b.innerHTML = '&times;';
                b.setAttribute('onclick', 'deleteTool(this, event)');
                header.appendChild(b);
            }
        });
        // Domains
        document.querySelectorAll('.domain-group').forEach(group => {
            const header = group.querySelector('.domain-header');
            if (header && !header.querySelector('.delete-btn-domain')) {
                const b = document.createElement('button');
                b.type = 'button';
                b.className = 'delete-btn delete-btn-domain';
                b.title = 'Domein verwijderen';
                b.innerHTML = '&times;';
                b.setAttribute('onclick', 'deleteDomain(this, event)');
                header.appendChild(b);
            }
        });
    }

    function deleteRow(btn, e) {
        if (e) { e.preventDefault(); e.stopPropagation(); }
        const row = btn.closest('.company-row');
        if (!row) return;
        const name = (row.querySelector('.company-row-name') || {}).textContent || 'dit bedrijf';
        if (!confirm('Bedrijf "' + name.trim() + '" verwijderen?')) return;
        const card = row.closest('.company-card');
        row.remove();
        // Update count chip
        if (card) {
            const countEl = card.querySelector('.tool-card-count');
            if (countEl) {
                const n = card.querySelectorAll('.company-row').length;
                countEl.textContent = n + (n === 1 ? ' Bedrijf' : ' Bedrijven');
            }
        }
        updateStats();
        if (typeof applyAllFilters === 'function') applyAllFilters();
        if (typeof showToast === 'function') showToast('Bedrijf verwijderd');
    }

    function deleteTool(btn, e) {
        if (e) { e.preventDefault(); e.stopPropagation(); }
        const card = btn.closest('.company-card');
        if (!card) return;
        const name = (card.querySelector('.tool-card-name') || {}).textContent || 'deze tool';
        const rowCount = card.querySelectorAll('.company-row').length;
        const msg = 'Tool "' + name.trim() + '" verwijderen?' +
            (rowCount > 0 ? '\n\nLet op: ' + rowCount + ' bedrijf/bedrijven binnen deze tool worden ook verwijderd.' : '');
        if (!confirm(msg)) return;
        card.remove();
        updateStats();
        if (typeof applyAllFilters === 'function') applyAllFilters();
        if (typeof showToast === 'function') showToast('Tool verwijderd');
    }

    function deleteDomain(btn, e) {
        if (e) { e.preventDefault(); e.stopPropagation(); }
        const group = btn.closest('.domain-group');
        if (!group) return;
        const name = (group.querySelector('.domain-title') || {}).textContent || 'dit domein';
        const toolCount = group.querySelectorAll('.company-card').length;
        const rowCount = group.querySelectorAll('.company-row').length;
        const msg = 'Domein "' + name.trim() + '" verwijderen?' +
            ((toolCount > 0 || rowCount > 0) ? '\n\nLet op: ' + toolCount + ' tool(s) en ' + rowCount + ' bedrijf/bedrijven worden ook verwijderd.' : '');
        if (!confirm(msg)) return;
        group.remove();
        updateStats();
        if (typeof applyAllFilters === 'function') applyAllFilters();
        if (typeof showToast === 'function') showToast('Domein verwijderd');
    }

    // ============================================
    //   SAVE CURRENT VERSION (download HTML snapshot)
    // ============================================
    function saveCurrentVersion(e) {
        if (e) e.preventDefault();

        // 1. Temporarily remove manage-mode & login state artifacts
        const wasManageMode = document.body.classList.contains('manage-mode');
        if (wasManageMode) document.body.classList.remove('manage-mode');

        // Reset login overlay to default (visible) state for saved file
        const overlay = document.getElementById('loginOverlay');
        const wasHidden = overlay && overlay.classList.contains('hidden');
        if (overlay) overlay.classList.remove('hidden');
        document.body.classList.add('logged-out');

        // Reset logout link text
        const logoutEl = document.getElementById('logoutUser');
        const oldLogoutText = logoutEl ? logoutEl.textContent : '';
        if (logoutEl) logoutEl.textContent = 'Uitloggen';

        // 2. Remove all injected delete buttons (they'll be re-injected on load)
        document.querySelectorAll('.delete-btn').forEach(b => b.remove());

        // 3. Capture current DOM as full HTML
        const html = '<!DOCTYPE html>\n' + document.documentElement.outerHTML;

        // 4. Restore current session state
        injectDeleteButtons();
        if (wasManageMode) document.body.classList.add('manage-mode');
        if (wasHidden && overlay) overlay.classList.add('hidden');
        document.body.classList.remove('logged-out');
        if (logoutEl && oldLogoutText) logoutEl.textContent = oldLogoutText;

        // 6. Download as file
        const blob = new Blob([html], { type: 'text/html;charset=utf-8' });
        const url = URL.createObjectURL(blob);
        const a = document.createElement('a');
        const today = new Date().toISOString().slice(0, 10);
        const time = new Date().toTimeString().slice(0, 5).replace(':', '');
        a.href = url;
        a.download = 'tooling-map_' + today + '_' + time + '.html';
        document.body.appendChild(a);
        a.click();
        document.body.removeChild(a);
        URL.revokeObjectURL(url);

        showToast('Versie opgeslagen als ' + a.download);
    }

    // ============================================
    //   ADD MODAL (handmatig toevoegen via UI)
    // ============================================
    function openAddModal(e) {
        if (e) e.preventDefault();
        populateAddDomainDropdowns();
        switchAddTab('company');
        document.getElementById('addModal').classList.add('open');
    }
    function closeAddModal() {
        document.getElementById('addModal').classList.remove('open');
        // reset inputs
        ['addCompanyName','addCompanyDetail','addToolName','addToolDesc','addDomainName','addDomainMeta']
            .forEach(id => { const el = document.getElementById(id); if (el) el.value = ''; });
    }
    function switchAddTab(tab) {
        document.querySelectorAll('.add-tab').forEach(b => b.classList.toggle('active', b.dataset.tab === tab));
        document.querySelectorAll('.add-panel').forEach(p => p.classList.toggle('active', p.dataset.panel === tab));
    }

    function populateAddDomainDropdowns() {
        const domains = [];
        document.querySelectorAll('.domain-group').forEach(g => {
            const t = (g.querySelector('.domain-title') || {}).textContent || '';
            if (t.trim()) domains.push(t.trim());
        });
        const makeOptions = (arr) => arr.map(n => `<option value="${escapeHtml(n)}">${escapeHtml(n)}</option>`).join('');
        const cd = document.getElementById('addCompanyDomain');
        const td = document.getElementById('addToolDomain');
        if (cd) cd.innerHTML = makeOptions(domains);
        if (td) td.innerHTML = makeOptions(domains);
        populateAddToolDropdown();
    }

    function populateAddToolDropdown() {
        const domainSel = document.getElementById('addCompanyDomain');
        const toolSel = document.getElementById('addCompanyTool');
        if (!domainSel || !toolSel) return;
        const domainName = domainSel.value;
        const tools = [];
        document.querySelectorAll('.domain-group').forEach(g => {
            const t = (g.querySelector('.domain-title') || {}).textContent || '';
            if (t.trim() === domainName) {
                g.querySelectorAll('.company-card').forEach(card => {
                    const n = (card.querySelector('.tool-card-name') || {}).textContent || '';
                    if (n.trim()) tools.push(n.trim());
                });
            }
        });
        toolSel.innerHTML = tools.length > 0
            ? tools.map(n => `<option value="${escapeHtml(n)}">${escapeHtml(n)}</option>`).join('')
            : '<option value="">— geen tools in dit domein —</option>';
    }

    function submitAdd() {
        const activePanel = document.querySelector('.add-panel.active');
        if (!activePanel) return;
        const kind = activePanel.dataset.panel;

        try {
            if (kind === 'domain') {
                const name = document.getElementById('addDomainName').value.trim();
                const meta = document.getElementById('addDomainMeta').value.trim() || 'nieuw domein';
                if (!name) { alert('Geef een domeinnaam op.'); return; }
                const mainEl = document.querySelector('.main');
                const res = findOrCreateDomain(name, mainEl);
                if (!res.created) {
                    showToast(`Domein "${name}" bestond al`);
                } else {
                    // Update meta
                    const metaEl = res.group.querySelector('.domain-meta');
                    if (metaEl) metaEl.textContent = meta;
                    showToast(`Domein "${name}" toegevoegd`);
                }
                res.group.scrollIntoView({ behavior: 'smooth', block: 'start' });
            }

            else if (kind === 'tool') {
                const domainName = document.getElementById('addToolDomain').value;
                const toolName = document.getElementById('addToolName').value.trim();
                const toolDesc = document.getElementById('addToolDesc').value.trim();
                if (!domainName) { alert('Kies een domein.'); return; }
                if (!toolName) { alert('Geef een toolnaam op.'); return; }
                const mainEl = document.querySelector('.main');
                const domain = findOrCreateDomain(domainName, mainEl);
                const toolRes = findOrCreateTool(domain.group, toolName, toolDesc);
                if (!toolRes.created) {
                    showToast(`Tool "${toolName}" bestond al in "${domainName}"`);
                } else {
                    showToast(`Tool "${toolName}" toegevoegd aan "${domainName}"`);
                }
                toolRes.card.scrollIntoView({ behavior: 'smooth', block: 'center' });
            }

            else if (kind === 'company') {
                const domainName = document.getElementById('addCompanyDomain').value;
                const toolName = document.getElementById('addCompanyTool').value;
                const companyName = document.getElementById('addCompanyName').value.trim();
                const detail = document.getElementById('addCompanyDetail').value.trim();
                const status = document.getElementById('addCompanyStatus').value;
                const country = document.getElementById('addCompanyCountry').value;
                if (!domainName) { alert('Kies een domein.'); return; }
                if (!toolName) { alert('Kies een tool (of voeg eerst een tool toe in dit domein).'); return; }
                if (!companyName) { alert('Geef een bedrijfsnaam op.'); return; }
                // Find card
                let card = null;
                document.querySelectorAll('.domain-group').forEach(g => {
                    const t = (g.querySelector('.domain-title') || {}).textContent || '';
                    if (t.trim() !== domainName) return;
                    g.querySelectorAll('.company-card').forEach(c => {
                        const n = (c.querySelector('.tool-card-name') || {}).textContent || '';
                        if (n.trim() === toolName) card = c;
                    });
                });
                if (!card) { alert('Kan de gekozen tool niet vinden.'); return; }
                addCompanyRow(card, companyName, detail, status, country);
                showToast(`Bedrijf "${companyName}" toegevoegd aan "${toolName}"`);
                // Scroll to the new row
                const rows = card.querySelectorAll('.company-row');
                if (rows.length) rows[rows.length - 1].scrollIntoView({ behavior: 'smooth', block: 'center' });
            }

            updateStats();
            if (typeof injectDeleteButtons === 'function') injectDeleteButtons();
            closeAddModal();
        } catch (err) {
            alert('Er ging iets mis: ' + err.message);
        }
    }
</script>

