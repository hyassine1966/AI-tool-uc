<!DOCTYPE html>
<html lang="nl">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Competitor AI Tools | United Consulting</title>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@200;300;400;500;600;700;800;900&display=swap" rel="stylesheet">
    <script src="https://cdnjs.cloudflare.com/ajax/libs/xlsx/0.18.5/xlsx.full.min.js"></script>
    <style>
        * { margin: 0; padding: 0; box-sizing: border-box; }

        :root {
            --uc-dark: #2d3440;
            --uc-medium: #6b7280;
            --uc-light: #f7f7f8;
            --uc-white: #ffffff;
            --uc-border: #e5e7eb;
            --uc-green: #15803d;
            --uc-green-bg: #e8f8ed;
            --uc-orange: #c2750a;
            --uc-orange-bg: #fef3e8;
            --uc-red: #dc2626;
            --uc-red-bg: #fee2e2;
            --uc-gray-dot: #6b7280;
            --uc-accent: #b8860b;
        }

        body {
            font-family: 'Inter', -apple-system, BlinkMacSystemFont, sans-serif;
            color: var(--uc-dark);
            background: var(--uc-white);
            -webkit-font-smoothing: antialiased;
        }

        /* === LOGIN OVERLAY === */
        .login-overlay {
            position: fixed; top: 0; left: 0; width: 100%; height: 100%;
            background: linear-gradient(135deg, #2d3440 0%, #1a1f28 100%);
            z-index: 99999;
            display: flex; align-items: center; justify-content: center;
        }
        .login-overlay.hidden { display: none; }
        .login-card {
            background: var(--uc-white);
            border-radius: 16px;
            padding: 48px 40px 40px;
            width: 100%; max-width: 400px;
            box-shadow: 0 20px 60px rgba(0,0,0,0.3);
            text-align: center;
        }
        .login-logo {
            display: flex; align-items: center; justify-content: center; gap: 12px;
            margin-bottom: 32px;
        }
        .login-logo-icon {
            width: 36px; height: 36px; border-radius: 8px;
            background: var(--uc-dark);
        }
        .login-logo-text {
            font-size: 13px; font-weight: 700; letter-spacing: 3px;
            text-transform: uppercase; color: var(--uc-dark); line-height: 1.2; text-align: left;
        }
        .login-title {
            font-size: 20px; font-weight: 700; color: var(--uc-dark); margin-bottom: 6px;
        }
        .login-subtitle {
            font-size: 13px; color: var(--uc-medium); margin-bottom: 28px;
        }
        .login-field {
            margin-bottom: 16px; text-align: left;
        }
        .login-label {
            display: block; font-size: 10px; font-weight: 700;
            letter-spacing: 1.5px; text-transform: uppercase;
            color: var(--uc-medium); margin-bottom: 6px;
        }
        .login-input {
            width: 100%; padding: 12px 14px;
            border: 1px solid var(--uc-border); border-radius: 8px;
            font-size: 14px; font-family: 'Inter', sans-serif;
            color: var(--uc-dark); background: var(--uc-light);
            transition: border-color 0.2s;
        }
        .login-input:focus {
            outline: none; border-color: var(--uc-dark); background: #fff;
        }
        .login-btn {
            width: 100%; padding: 14px;
            background: var(--uc-dark); color: #fff;
            border: none; border-radius: 8px;
            font-size: 13px; font-weight: 700;
            letter-spacing: 1.5px; text-transform: uppercase;
            cursor: pointer; margin-top: 8px;
            font-family: 'Inter', sans-serif;
            transition: background 0.2s;
        }
        .login-btn:hover { background: #1a1f28; }
        .login-error {
            color: var(--uc-red); font-size: 12px; font-weight: 500;
            margin-top: 12px; min-height: 18px;
        }
        .login-session {
            font-size: 11px; color: var(--uc-medium); margin-top: 20px;
        }
        .login-session a {
            color: var(--uc-dark); cursor: pointer; text-decoration: underline;
        }

        body.logged-out .navbar,
        body.logged-out .hero,
        body.logged-out .stats-bar,
        body.logged-out .main,
        body.logged-out .toast { visibility: hidden; }

        /* === NAVBAR === */
        .navbar {
            position: sticky;
            top: 0;
            z-index: 1000;
            background: var(--uc-white);
            border-bottom: 1px solid var(--uc-border);
        }
        .navbar-inner {
            max-width: 1400px;
            margin: 0 auto;
            padding: 0 48px;
            height: 68px;
            display: flex;
            align-items: center;
            justify-content: space-between;
        }
        .logo { display: flex; align-items: center; gap: 12px; text-decoration: none; color: var(--uc-dark); }
        .logo-icon {
            width: 36px; height: 36px;
            border: 2.5px solid var(--uc-dark);
            border-radius: 3px;
            position: relative;
        }
        .logo-icon::after {
            content: '';
            position: absolute;
            top: 5px; left: 5px;
            width: 14px; height: 14px;
            background: var(--uc-dark);
            border-radius: 2px;
        }
        .logo-text { font-size: 13px; font-weight: 500; line-height: 1.2; }
        .nav-links { display: flex; align-items: center; gap: 36px; list-style: none; }
        .nav-links a {
            text-decoration: none; color: var(--uc-dark);
            font-size: 11px; font-weight: 600;
            letter-spacing: 2px; text-transform: uppercase;
            padding-bottom: 4px;
        }
        .nav-links a.active { border-bottom: 2px solid var(--uc-dark); }

        /* === HERO === */
        .hero { background: var(--uc-dark); text-align: center; padding: 64px 48px 56px; }
        .hero-title {
            font-size: clamp(36px, 5vw, 56px);
            font-weight: 300;
            color: var(--uc-white);
            letter-spacing: 4px;
            text-transform: uppercase;
            line-height: 1.15;
            margin-bottom: 18px;
        }
        .hero-title strong { font-weight: 800; }
        .hero-subtitle {
            font-size: 15px; font-weight: 300;
            color: rgba(255,255,255,0.65);
            max-width: 500px; margin: 0 auto; line-height: 1.6;
        }

        /* === STATS + FILTER BAR === */
        .stats-bar {
            position: sticky;
            top: 68px;
            z-index: 100;
            background: var(--uc-white);
            border-bottom: 1px solid var(--uc-border);
            padding: 18px 48px;
        }
        .stats-bar-inner {
            max-width: 1400px; margin: 0 auto;
            display: flex; align-items: center; gap: 12px; flex-wrap: wrap;
        }
        .stat-chip { display: flex; align-items: baseline; gap: 6px; margin-right: 16px; }
        .stat-chip .num { font-size: 22px; font-weight: 800; color: var(--uc-dark); }
        .stat-chip .lbl {
            font-size: 10px; font-weight: 600;
            letter-spacing: 1.5px; text-transform: uppercase; color: var(--uc-medium);
        }
        .spacer { flex: 1; }

        .filter-dots { display: flex; align-items: center; gap: 20px; }
        .filter-dot-btn {
            display: flex; align-items: center; gap: 6px;
            background: none; border: none; cursor: pointer;
            font-family: 'Inter', sans-serif;
            font-size: 10px; font-weight: 600; letter-spacing: 1.5px;
            text-transform: uppercase; color: var(--uc-medium);
            padding: 6px 10px; border-radius: 6px;
            transition: background 0.15s;
        }
        .filter-dot-btn:hover { background: var(--uc-light); }
        .filter-dot-btn.active { color: var(--uc-dark); background: var(--uc-light); }
        .filter-dot-btn .dot { width: 8px; height: 8px; border-radius: 50%; }
        .dot-all { background: var(--uc-gray-dot); }
        .dot-bevestigd { background: var(--uc-green); }
        .dot-waarschijnlijk { background: var(--uc-orange); }
        .dot-mogelijk { background: var(--uc-red); }

        /* === COUNTRY FILTER === */
        .filter-divider {
            width: 1px; height: 20px;
            background: var(--uc-border);
            margin: 0 4px;
        }
        .country-flag-sm {
            display: inline-block;
            width: 14px; height: 10px;
            border-radius: 2px;
            overflow: hidden;
            box-shadow: 0 0 0 1px rgba(0,0,0,0.08);
            flex-shrink: 0;
            vertical-align: middle;
        }
        .flag-be {
            background: linear-gradient(to right,
                #000 0%, #000 33.3%,
                #FFD90C 33.3%, #FFD90C 66.6%,
                #EF3340 66.6%, #EF3340 100%);
        }
        .flag-nl {
            background: linear-gradient(to bottom,
                #AE1C28 0%, #AE1C28 33.3%,
                #FFFFFF 33.3%, #FFFFFF 66.6%,
                #21468B 66.6%, #21468B 100%);
        }

        /* === COUNTRY CHIP ON ROW === */
        .country-chip {
            flex-shrink: 0;
            display: inline-flex; align-items: center; gap: 5px;
            font-size: 9px; font-weight: 700;
            letter-spacing: 1px; text-transform: uppercase;
            color: var(--uc-medium);
            padding: 3px 7px;
            border: 1px solid var(--uc-border);
            border-radius: 4px;
            background: var(--uc-white);
            white-space: nowrap;
        }
        .country-chip .country-flag-sm { box-shadow: none; }

        .search-box {
            display: flex; align-items: center; gap: 8px;
            padding: 8px 16px;
            border: 1px solid var(--uc-border);
            border-radius: 6px;
            background: var(--uc-white);
            min-width: 220px;
        }
        .search-box svg { width: 16px; height: 16px; color: var(--uc-medium); flex-shrink: 0; }
        .search-box input {
            border: none; outline: none;
            font-family: 'Inter', sans-serif;
            font-size: 13px; color: var(--uc-dark);
            width: 100%; background: transparent;
        }
        .search-box input::placeholder { color: #b0b5bd; }

        /* === MAIN CONTENT === */
        .main { max-width: 1400px; margin: 0 auto; padding: 40px 48px 80px; }

        /* === DOMAIN / CATEGORY GROUP === */
        .domain-group { margin-bottom: 48px; }
        .domain-header {
            display: flex; align-items: center; gap: 16px;
            padding-bottom: 16px;
            border-bottom: 1px solid var(--uc-border);
            margin-bottom: 28px;
            cursor: pointer; user-select: none;
        }
        .domain-accent {
            width: 4px; height: 32px;
            background: var(--uc-dark);
            border-radius: 2px; flex-shrink: 0;
        }
        .domain-group.big5 .domain-accent { background: var(--uc-accent); width: 6px; }
        .domain-group.big5 .domain-title::before {
            content: 'BIG5';
            display: inline-block;
            background: var(--uc-accent); color: #fff;
            font-size: 10px; font-weight: 800;
            letter-spacing: 1.5px;
            padding: 3px 8px; border-radius: 4px;
            margin-right: 12px;
            vertical-align: middle;
        }
        .domain-title { font-size: 22px; font-weight: 700; color: var(--uc-dark); }
        .domain-meta {
            font-size: 11px; font-weight: 500;
            letter-spacing: 1.5px; text-transform: uppercase; color: var(--uc-medium);
        }
        .domain-toggle {
            margin-left: auto;
            width: 28px; height: 28px;
            display: flex; align-items: center; justify-content: center;
            border-radius: 6px;
            transition: all 0.2s;
            color: var(--uc-medium);
        }
        .domain-toggle svg { width: 18px; height: 18px; transition: transform 0.25s ease; }
        .domain-header:hover .domain-toggle { background: var(--uc-light); }
        .domain-group.collapsed .domain-toggle svg { transform: rotate(180deg); }
        .domain-group.collapsed .companies-grid { display: none; }

        /* === COMPANY CARDS GRID === */
        .companies-grid {
            display: grid;
            grid-template-columns: repeat(auto-fill, minmax(380px, 1fr));
            gap: 20px;
        }

        .company-card {
            border: 1px solid var(--uc-border);
            border-radius: 10px;
            overflow: visible;
            transition: box-shadow 0.2s;
        }
        .company-card:hover { box-shadow: 0 2px 16px rgba(0,0,0,0.06); }
        .tool-card-header {
            display: flex; align-items: center; justify-content: space-between;
            padding: 20px 24px 16px;
        }
        .tool-card-name { font-size: 16px; font-weight: 700; color: var(--uc-dark); }
        .tool-card-count {
            font-size: 10px; font-weight: 600;
            letter-spacing: 1.5px; text-transform: uppercase; color: var(--uc-medium);
            border: 1px solid var(--uc-border);
            border-radius: 4px; padding: 4px 10px; white-space: nowrap;
        }
        .tool-card-desc {
            font-size: 13px; font-weight: 400; color: var(--uc-medium);
            line-height: 1.5; padding: 0 24px 14px;
        }

        /* === DELETE BUTTONS (visible in manage-mode) === */
        .delete-btn {
            display: none;
            background: #fff;
            border: 1px solid #f0c2c2;
            color: #c0392b;
            width: 22px; height: 22px;
            border-radius: 50%;
            font-size: 14px; line-height: 1;
            cursor: pointer;
            align-items: center; justify-content: center;
            padding: 0;
            flex-shrink: 0;
            transition: background 0.15s, color 0.15s;
            font-family: 'Inter', sans-serif;
        }
        .delete-btn:hover { background: #c0392b; color: #fff; }
        body.manage-mode .delete-btn { display: inline-flex; }
        body.manage-mode .domain-header { padding-right: 70px; position: relative; }
        .delete-btn-domain {
            position: absolute;
            right: 56px;
            top: 50%;
            transform: translateY(-50%);
            z-index: 2;
        }
        .delete-btn-tool { margin-left: 8px; }
        .delete-btn-row { margin-left: 6px; align-self: center; }
        #manageToggleLink.active { color: #c0392b; font-weight: 700; }
        body.manage-mode .company-row { outline: 1px dashed rgba(192, 57, 43, 0.15); }

        /* === COMPANY ROWS INSIDE TOOL CARD === */
        .company-row {
            display: flex; align-items: flex-start; gap: 12px;
            padding: 14px 24px;
            border-top: 1px solid var(--uc-border);
            background: var(--uc-light);
            position: relative; z-index: 1;
        }
        .company-row.dd-open { z-index: 9001; }
        .company-row:nth-child(odd) { background: var(--uc-white); }
        .company-row:last-child { border-radius: 0 0 10px 10px; }
        .company-row-info { flex: 1; min-width: 0; }
        .company-row-name {
            font-size: 14px; font-weight: 600; color: var(--uc-dark); margin-bottom: 3px;
        }
        .company-row-detail {
            font-size: 12px; font-weight: 400; color: var(--uc-medium); line-height: 1.5;
        }

        /* === STATUS BADGE (clickable) === */
        .status-badge {
            flex-shrink: 0;
            font-size: 9px; font-weight: 700;
            letter-spacing: 1.2px; text-transform: uppercase;
            padding: 4px 10px; border-radius: 4px;
            border: none; cursor: pointer;
            font-family: 'Inter', sans-serif;
            position: relative; white-space: nowrap;
            transition: filter 0.15s;
        }
        .status-badge:hover { filter: brightness(0.92); }
        .status-badge[data-status="bevestigd"] { background: var(--uc-green-bg); color: var(--uc-green); }
        .status-badge[data-status="waarschijnlijk"] { background: var(--uc-orange-bg); color: var(--uc-orange); }
        .status-badge[data-status="mogelijk"] { background: var(--uc-red-bg); color: var(--uc-red); }

        /* Status Dropdown */
        .status-dd {
            position: absolute; top: calc(100% + 4px); right: 0;
            background: var(--uc-white);
            border: 1px solid var(--uc-border);
            border-radius: 8px;
            box-shadow: 0 8px 24px rgba(0,0,0,0.15);
            z-index: 9000;
            min-width: 180px; padding: 5px;
            display: none;
        }
        .status-dd.open { display: block; animation: ddFade 0.12s ease; }
        @keyframes ddFade { from { opacity: 0; transform: translateY(-3px); } to { opacity: 1; transform: translateY(0); } }
        .status-dd-opt {
            display: flex; align-items: center; gap: 8px;
            padding: 7px 10px; border-radius: 5px;
            cursor: pointer;
            font-size: 11px; font-weight: 600; letter-spacing: 0.5px;
            border: none; background: none;
            width: 100%; text-align: left;
            font-family: 'Inter', sans-serif;
        }
        .status-dd-opt:hover { background: var(--uc-light); }
        .status-dd-opt .dd-dot { width: 7px; height: 7px; border-radius: 50%; flex-shrink: 0; }
        .status-dd-opt .dd-check { margin-left: auto; opacity: 0; font-size: 13px; }
        .status-dd-opt.sel .dd-check { opacity: 1; }
        .status-dd-opt[data-val="bevestigd"] { color: var(--uc-green); }
        .status-dd-opt[data-val="bevestigd"] .dd-dot { background: var(--uc-green); }
        .status-dd-opt[data-val="waarschijnlijk"] { color: var(--uc-orange); }
        .status-dd-opt[data-val="waarschijnlijk"] .dd-dot { background: var(--uc-orange); }
        .status-dd-opt[data-val="mogelijk"] { color: var(--uc-red); }
        .status-dd-opt[data-val="mogelijk"] .dd-dot { background: var(--uc-red); }

        /* === EDIT MODE === */
        [contenteditable="true"]:focus {
            outline: 2px dashed rgba(45,52,64,0.25);
            outline-offset: 3px;
            border-radius: 3px;
        }
        .edit-banner {
            position: fixed;
            bottom: 24px; right: 24px;
            background: var(--uc-dark); color: var(--uc-white);
            padding: 12px 20px; border-radius: 10px;
            font-size: 12px; font-weight: 500;
            z-index: 9999;
            box-shadow: 0 6px 24px rgba(0,0,0,0.15);
            display: flex; align-items: center; gap: 8px;
            cursor: pointer; transition: transform 0.15s;
        }
        .edit-banner:hover { transform: translateY(-2px); }
        .edit-dot {
            width: 7px; height: 7px;
            border-radius: 50%; background: #4ade80;
            animation: pulse 2s infinite;
        }
        @keyframes pulse { 0%,100% { opacity:1; } 50% { opacity:0.5; } }

        /* === IMPORT MODAL === */
        .modal-overlay {
            position: fixed; inset: 0;
            background: rgba(45,52,64,0.55);
            z-index: 10000;
            display: none;
            align-items: center; justify-content: center;
            padding: 20px;
        }
        .modal-overlay.open { display: flex; }
        .modal-box {
            background: #fff;
            border-radius: 12px;
            width: 100%; max-width: 620px;
            padding: 28px 28px 24px;
            box-shadow: 0 20px 60px rgba(0,0,0,0.25);
            max-height: 90vh; overflow-y: auto;
        }
        .modal-title {
            font-size: 18px; font-weight: 700; color: var(--uc-dark);
            margin-bottom: 8px;
        }
        .modal-sub {
            font-size: 12px; font-weight: 400; color: var(--uc-medium);
            line-height: 1.6; margin-bottom: 16px;
        }
        .modal-example {
            background: var(--uc-light);
            border: 1px solid var(--uc-border);
            border-radius: 6px;
            padding: 12px 14px;
            font-family: 'Courier New', monospace;
            font-size: 11px; color: var(--uc-dark);
            line-height: 1.6;
            white-space: pre;
            overflow-x: auto;
            margin-bottom: 16px;
        }
        .modal-actions {
            display: flex; gap: 10px; justify-content: flex-end;
            margin-top: 18px;
        }
        .modal-btn {
            padding: 10px 18px; border-radius: 6px;
            font-family: 'Inter', sans-serif;
            font-size: 11px; font-weight: 600;
            letter-spacing: 1.5px; text-transform: uppercase;
            cursor: pointer; border: 1px solid var(--uc-border);
            background: #fff; color: var(--uc-dark);
        }
        .modal-btn.primary {
            background: var(--uc-dark); color: #fff; border-color: var(--uc-dark);
        }
        .modal-btn:hover { filter: brightness(0.95); }

        /* === ADD MODAL (tabs + form) === */
        .add-tabs {
            display: flex; gap: 6px;
            margin-bottom: 18px;
            border-bottom: 1px solid var(--uc-border);
        }
        .add-tab {
            padding: 10px 16px;
            font-family: 'Inter', sans-serif;
            font-size: 11px; font-weight: 600;
            letter-spacing: 1.5px; text-transform: uppercase;
            color: var(--uc-medium);
            background: none; border: none; cursor: pointer;
            border-bottom: 2px solid transparent;
            margin-bottom: -1px;
        }
        .add-tab.active { color: var(--uc-dark); border-bottom-color: var(--uc-dark); }
        .add-tab:hover { color: var(--uc-dark); }

        .add-panel { display: none; }
        .add-panel.active { display: block; }

        .form-field { margin-bottom: 14px; }
        .form-label {
            display: block;
            font-size: 10px; font-weight: 700;
            letter-spacing: 1.2px; text-transform: uppercase;
            color: var(--uc-medium);
            margin-bottom: 6px;
        }
        .form-input, .form-select, .form-textarea {
            width: 100%;
            padding: 10px 12px;
            border: 1px solid var(--uc-border);
            border-radius: 6px;
            background: #fff;
            font-family: 'Inter', sans-serif;
            font-size: 13px; color: var(--uc-dark);
            box-sizing: border-box;
        }
        .form-input:focus, .form-select:focus, .form-textarea:focus {
            outline: none;
            border-color: var(--uc-dark);
        }
        .form-textarea { min-height: 72px; resize: vertical; }
        .form-row { display: flex; gap: 10px; }
        .form-row > .form-field { flex: 1; }
        .toast {
            position: fixed; top: 24px; left: 50%;
            transform: translateX(-50%);
            background: var(--uc-dark); color: #fff;
            padding: 12px 20px; border-radius: 8px;
            font-size: 12px; font-weight: 500;
            box-shadow: 0 6px 24px rgba(0,0,0,0.2);
            z-index: 10001;
            opacity: 0; transition: opacity 0.25s;
            pointer-events: none;
        }
        .toast.show { opacity: 1; }

        /* === RESPONSIVE === */
        @media (max-width: 900px) {
            .navbar-inner, .stats-bar, .main { padding-left: 20px; padding-right: 20px; }
            .companies-grid { grid-template-columns: 1fr; }
            .stats-bar-inner { flex-direction: column; align-items: flex-start; gap: 12px; }
            .filter-dots { flex-wrap: wrap; }
            .nav-links { gap: 20px; }
            .nav-links a { font-size: 10px; letter-spacing: 1.5px; }
        }
    </style>
</head>
<body class="logged-out">

<!-- LOGIN OVERLAY -->
<div class="login-overlay" id="loginOverlay">
    <div class="login-card">
        <div class="login-logo">
            <div class="login-logo-icon"></div>
            <div class="login-logo-text">united<br>consulting</div>
        </div>
        <div class="login-title">Competitor AI Tools</div>
        <div class="login-subtitle">Log in om toegang te krijgen tot de tool.</div>
        <form onsubmit="handleLogin(event)">
            <div class="login-field">
