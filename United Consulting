<script>
    // ============================================
    //   AUTHENTICATION (client-side)
    // ============================================
    (function() {
        // Simple hash to avoid plain-text passwords in source
        function simpleHash(str) {
            let h = 0;
            for (let i = 0; i < str.length; i++) {
                h = ((h << 5) - h) + str.charCodeAt(i);
                h |= 0;
            }
            return h.toString(36);
        }

        // Registered accounts: [username, passwordHash, displayName]
        var accounts = [
            ['jeroen.baeten@unitedconsulting.be', simpleHash('JerBae467'), 'Jeroen'],
            ['kristof.stevens@unitdconsulting.be', simpleHash('KriSte736'), 'Kristof']
        ];

        window._authAccounts = accounts;
        window._simpleHash = simpleHash;

        // Check for existing session
        var session = null;
        try { session = JSON.parse(sessionStorage.getItem('uc_session')); } catch(e) {}
        if (session && session.user) {
            unlockApp(session.displayName);
        }

        function unlockApp(displayName) {
            document.body.classList.remove('logged-out');
            var overlay = document.getElementById('loginOverlay');
            if (overlay) overlay.classList.add('hidden');
            // Update logout link when DOM is ready
            function setLogout() {
                var el = document.getElementById('logoutUser');
                if (el) el.textContent = displayName + ' — Uitloggen';
            }
            if (document.readyState === 'loading') {
                document.addEventListener('DOMContentLoaded', setLogout);
            } else {
                setLogout();
            }
        }

        window.handleLogin = function(e) {
            e.preventDefault();
            var email = document.getElementById('loginEmail').value.trim().toLowerCase();
            var pass = document.getElementById('loginPassword').value;
            var errorEl = document.getElementById('loginError');
            var hashed = simpleHash(pass);

            var found = null;
            for (var i = 0; i < accounts.length; i++) {
                if (accounts[i][0] === email && accounts[i][1] === hashed) {
                    found = accounts[i];
                    break;
                }
            }

            if (found) {
                errorEl.textContent = '';
                try {
                    sessionStorage.setItem('uc_session', JSON.stringify({
                        user: found[0],
                        displayName: found[2],
                        loginTime: new Date().toISOString()
                    }));
                } catch(e) {}
                unlockApp(found[2]);
            } else {
                errorEl.textContent = 'Ongeldige gebruikersnaam of wachtwoord.';
                document.getElementById('loginPassword').value = '';
                document.getElementById('loginPassword').focus();
            }
        };

        window.handleLogout = function(e) {
            if (e) e.preventDefault();
            try { sessionStorage.removeItem('uc_session'); } catch(e) {}
            document.body.classList.add('logged-out');
            var overlay = document.getElementById('loginOverlay');
            if (overlay) overlay.classList.remove('hidden');
            document.getElementById('loginEmail').value = '';
            document.getElementById('loginPassword').value = '';
            document.getElementById('loginError').textContent = '';
            document.getElementById('loginEmail').focus();
        };
    })();
</script>

